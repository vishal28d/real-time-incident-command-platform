{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "event-envelope.v1",
  "title": "EventEnvelopeV1",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "schemaVersion",
    "occurredAt",
    "incidentId",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "eventType": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "traceId": {
      "type": "string"
    },
    "incidentId": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
